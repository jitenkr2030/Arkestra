# Database - SQLite for local development
# For Turso (SQLite on Edge), use: libsql://your-database-name.turso.io
# DATABASE_URL="file:./dev.db"

# For production with Turso:
# DATABASE_URL="libsql://your-database-name.turso.io"
# TURSO_DATABASE_AUTH_TOKEN="your-turso-auth-token"

# NextAuth - Generate a secure secret at: https://generate-secret.vercel.app/
NEXTAUTH_URL="https://your-app.vercel.app"
NEXTAUTH_SECRET="your-super-secret-key-change-this-in-production"

# Application
NEXT_PUBLIC_APP_NAME="SymphonyHub"
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"